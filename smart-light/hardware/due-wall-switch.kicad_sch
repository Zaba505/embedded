		(margins 1.27 1.27 1.27 1.27)
		(stroke
			(width 0.254)
			(type default)
		)
		(fill
			(type color)
			(color 232 232 232 1)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "5a170004-0000-4000-8000-000000000023")
